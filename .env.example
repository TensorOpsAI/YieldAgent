# Meta Marketing API — required for the Meta MCP server
# Create a test ad account in Meta Business Manager and a system user token with
# `ads_management` scope. The MCP server refuses to operate on non-test accounts
# unless YIELDAGENT_ALLOW_LIVE=1 is set.
META_ACCESS_TOKEN=
META_AD_ACCOUNT_ID=          # the numeric account id, with or without the act_ prefix
META_PAGE_ID=                # required to create ads
META_API_VERSION=v22.0

# Provider OAuth client credentials below are OPTIONAL — the web UI accepts them
# through Connections → Setup and encrypts them locally in .yieldagent/connections.json.
# Set them here only if you want to pre-fill them for scripted / CI setups.

# Meta Marketing API OAuth (web onboarding)
META_APP_ID=
META_APP_SECRET=

# LinkedIn Ads OAuth (web onboarding)
# Register http://localhost:3000/api/oauth/linkedin/callback as an authorized redirect URL
# in your LinkedIn Developer app. The app must have Advertising API permissions for
# r_ads / r_ads_reporting to work.
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
LINKEDIN_REDIRECT_URI=http://localhost:3000/api/oauth/linkedin/callback
LINKEDIN_OAUTH_SCOPES=r_ads r_ads_reporting
LINKEDIN_API_VERSION=202605

# Local token encryption key. If unset, the app auto-generates one at
# .yieldagent/secret.key (mode 0600) on first credential save. Set this only if
# you want to supply / rotate the key yourself. Must be 32+ chars.
YIELDAGENT_SECRET_KEY=

# Google Ads OAuth (web onboarding)
GOOGLE_ADS_CLIENT_ID=
GOOGLE_ADS_CLIENT_SECRET=
GOOGLE_ADS_DEVELOPER_TOKEN=    # 22-char token from your Google Ads API Center
GOOGLE_ADS_LOGIN_CUSTOMER_ID=  # optional: 10-digit MCC customer id without dashes

# Anthropic — required for the campaign-setup agent
ANTHROPIC_API_KEY=

# Set to 1 only if you knowingly want to run against a live ad account.
# Leave unset for normal development.
# YIELDAGENT_ALLOW_LIVE=1
