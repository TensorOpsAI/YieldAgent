# ===== LLM provider =====
# Pick one provider by setting the matching key. The model is chosen via the
# `--model` CLI flag (default: gemini-2.5-flash). init_chat_model infers the
# provider from the model name (claude-* → anthropic, gpt-* → openai). A bare
# gemini-* is rewritten to google_genai:gemini-* (Google AI Studio, needs only
# GOOGLE_API_KEY) — pass google_vertexai:gemini-* explicitly for Vertex AI.
GOOGLE_API_KEY=
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=

# ===== LinkedIn Marketing API — required for the LinkedIn MCP server =====
# Generate at https://www.linkedin.com/developers/tools/oauth/token-generator
# Required scopes: r_ads, rw_ads, r_ads_reporting. Tokens expire in 60 days.
LINKEDIN_ACCESS_TOKEN=
LINKEDIN_AD_ACCOUNT_ID=          # numeric account id, with or without the urn:li:sponsoredAccount: prefix
LINKEDIN_ALLOWED_AD_ACCOUNTS=    # comma-separated allowlist; account above must be in this list
# LINKEDIN_API_VERSION=202405

# ===== Meta Marketing API — required for the Meta MCP server =====
# Create a test ad account in Meta Business Manager and a system user token with
# `ads_management` scope. The MCP server refuses to operate on non-test accounts
# unless YIELDAGENT_ALLOW_LIVE=1 is set.
META_ACCESS_TOKEN=
META_AD_ACCOUNT_ID=              # the numeric account id, with or without the act_ prefix
META_PAGE_ID=                    # required to create ads
META_API_VERSION=v22.0

# Set to 1 only if you knowingly want to run against a live ad account.
# Leave unset for normal development.
# YIELDAGENT_ALLOW_LIVE=1
