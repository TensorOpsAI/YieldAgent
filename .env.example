# Copy to `.env` and fill in. Load with: set -a; source .env; set +a
# Nothing here is required to browse the console; you need an LLM key to chat and
# LinkedIn credentials to plan/create real drafts.

# ===== LLM provider (required to chat) =====
# Set the key for the provider you want. The console picks a model per request
# from the UI; the CLI agents take --model. init_chat_model infers the provider
# from the model name: claude-* -> anthropic, gpt-* -> openai, and a bare
# gemini-* is rewritten to google_genai:gemini-* (Google AI Studio, needs only
# GOOGLE_API_KEY) -- pass google_vertexai:gemini-* explicitly for Vertex AI.
GOOGLE_API_KEY=
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=

# Default model when a request does not specify one (console + CLI).
# YIELDAGENT_CONSOLE_MODEL=gemini-3.1-pro-preview

# ===== LinkedIn Marketing API (required to plan/create LinkedIn drafts) =====
# Generate at https://www.linkedin.com/developers/tools/oauth/token-generator
# Required scopes: r_ads, rw_ads, r_ads_reporting. Tokens expire in 60 days.
LINKEDIN_ACCESS_TOKEN=
LINKEDIN_AD_ACCOUNT_ID=          # numeric account id, with or without the urn:li:sponsoredAccount: prefix
LINKEDIN_ALLOWED_AD_ACCOUNTS=    # comma-separated allowlist; the account above must be in this list
# Org behind sponsored posts. Optional: falls back to the page linked to the ad
# account. Accepts a bare org id or a full urn:li:organization: URN.
# LINKEDIN_ORGANIZATION_URN=
# LINKEDIN_API_VERSION=202605

# ===== Meta Marketing API (optional; the Meta connector is not wired in yet) =====
# Create a test ad account in Meta Business Manager and a system user token with
# `ads_management` scope. The MCP server refuses non-test accounts unless
# YIELDAGENT_ALLOW_LIVE=1 is set.
# META_ACCESS_TOKEN=
# META_AD_ACCOUNT_ID=            # numeric account id, with or without the act_ prefix
# META_PAGE_ID=                  # required to create ads
# META_API_VERSION=v22.0

# ===== Misc =====
# SQLite path for the console's saved-campaign store. Defaults to ./yieldagent.db
# YIELDAGENT_DB=yieldagent.db

# Set to 1 only if you knowingly want to run against a live (non-test) ad account.
# Leave unset for normal development. NEVER combine with --auto-approve.
# YIELDAGENT_ALLOW_LIVE=1
