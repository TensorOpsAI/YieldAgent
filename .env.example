# Copy to `.env` and fill in the secrets. `yieldagent.env.load_dotenv` reads
# this file automatically when you run the CLI or MCP servers — no need for
# `set -a; source .env; set +a`.

# ===== LLM provider =====
# Default model is `gemini-2.5-flash`. Override at runtime with --model.
# init_chat_model infers the provider from the model name (gemini-* → google,
# claude-* → anthropic, gpt-* → openai), or pass an explicit "provider:model"
# string like `google_genai:gemini-2.5-pro`.
GOOGLE_API_KEY=
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=

# ===== LinkedIn Marketing API — required for the LinkedIn MCP server =====
# Get a 3-legged OAuth access token via the Authorization Code flow against
# the Advertising Agent app. Required scopes: `r_ads`, `rw_ads`,
# `r_ads_reporting`. Tokens expire after ~60 days.
LINKEDIN_ACCESS_TOKEN=
LINKEDIN_AD_ACCOUNT_ID=          # numeric account id, with or without the urn:li:sponsoredAccount: prefix
LINKEDIN_ALLOWED_AD_ACCOUNTS=    # comma-separated allowlist; the configured account must be in this list

# Versioned API header. Bump as LinkedIn releases new versions.
# LINKEDIN_API_VERSION=202605

# ===== Meta Marketing API — required for the Meta MCP server =====
# Create a test ad account in Meta Business Manager and a system user token
# with `ads_management` scope. The MCP server refuses to operate on non-test
# accounts unless YIELDAGENT_ALLOW_LIVE=1 is set.
META_ACCESS_TOKEN=
META_AD_ACCOUNT_ID=              # numeric account id, with or without the `act_` prefix
META_PAGE_ID=                    # required to create ads
META_API_VERSION=v22.0

# ===== Global safety override — leave UNSET =====
# Setting this to 1 disables the LinkedIn ad-account allowlist guard. Only
# enable if you fully understand what you're doing.
# YIELDAGENT_ALLOW_LIVE=1
